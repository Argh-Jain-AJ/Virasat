      "name": "eventController.js",
      "filePath": "backend/controllers/eventController.js",
      "summary": "Controller that builds a unified, chronologically sorted family timeline by combining birth/death events derived from person records with linked memory entries.",
      "tags": ["api-handler", "controller", "timeline", "family-events"],
      "complexity": "moderate",
      "languageNotes": "Silently swallows per-person memory fetch errors inside the aggregation loop to keep building the timeline even if one lookup fails."
    },
